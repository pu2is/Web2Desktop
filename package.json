{
  "author": {
    "name": "baz405",
    "email": "foo.425.123@gmail.com"
  },
  "name": "chatgpt",
  "version": "0.1.0",
  "description": "Minimal, auditable Electron desktop shell for a web app URL",
  "main": "main.js",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "electron .",
    "lint": "echo \"No lint configured\"",
    "make": "electron-builder --linux deb",
    "make:appimage": "electron-builder --linux AppImage",
    "make:dir": "electron-builder --linux dir"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.chatgpt.shell",
    "productName": "ChatGPT",
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "package.json",
      "README.md"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "icons",
      "category": "Utility"
    }
  }
}
